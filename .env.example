# Configuración del servidor DEVELOP (no es producción).
DJANGO_SETTINGS_MODULE=config.settings.develop
DEBUG=False
ALLOWED_HOSTS=dominio-o-ip-del-develop
CSRF_TRUSTED_ORIGINS=https://dominio-del-develop

SECRET_KEY=

# Base de datos: SIEMPRE MySQL (charset utf8mb4 ya forzado en settings).
DATABASE_URL=mysql://USUARIO:CLAVE@HOST:3306/NOMBRE_BD

# Keycloak / OIDC (client del realm para DEVELOP)
OIDC_RP_CLIENT_ID=rondas-web
OIDC_RP_CLIENT_SECRET=
OIDC_OP_AUTHORIZATION_ENDPOINT=https://sso.ayressecurity.cl/realms/ayres-security/protocol/openid-connect/auth
OIDC_OP_TOKEN_ENDPOINT=https://sso.ayressecurity.cl/realms/ayres-security/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=https://sso.ayressecurity.cl/realms/ayres-security/protocol/openid-connect/userinfo
OIDC_OP_JWKS_ENDPOINT=https://sso.ayressecurity.cl/realms/ayres-security/protocol/openid-connect/certs
OIDC_OP_LOGOUT_ENDPOINT=https://sso.ayressecurity.cl/realms/ayres-security/protocol/openid-connect/logout
# True en servidor (cert válido). False solo si el SSO usa cert self-signed.
OIDC_VERIFY_SSL=True
